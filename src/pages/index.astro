    let isDragging = false;
    let startX = 0, startY = 0;
    let popupEl: HTMLElement | null = null;
    let initialLeft = 0, initialTop = 0;

    function startPopupDrag(clientX: number, clientY: number, target: HTMLElement) {
      if (target.closest('.popup-close')) return;
      isDragging = true;
      popupEl = (handle as HTMLElement).closest('.virus-popup') as HTMLElement;
      if (popupEl) {
        // Pegar posição atual do popup
        const rect = popupEl.getBoundingClientRect();
        initialLeft = rect.left;
        initialTop = rect.top;
        startX = clientX;
        startY = clientY;
        bringPopupToFront(popupEl);
        // Adicionar classe para indicar que está arrastando
        popupEl.style.transition = 'none';
      }
    }

    function movePopupDrag(clientX: number, clientY: number) {
      if (!isDragging || !popupEl) return;

      // Calcular delta do movimento
      const deltaX = clientX - startX;
      const deltaY = clientY - startY;

      // Nova posição
      let newX = initialLeft + deltaX;
      let newY = initialTop + deltaY;

      // Limitar aos bounds da tela (com margem)
      const popupWidth = popupEl.offsetWidth;
      const popupHeight = popupEl.offsetHeight;
      const maxX = window.innerWidth - 50;
      const maxY = window.innerHeight - 60;

      newX = Math.max(-popupWidth + 50, Math.min(newX, maxX));
      newY = Math.max(0, Math.min(newY, maxY));

      popupEl.style.left = newX + 'px';
      popupEl.style.top = newY + 'px';
    }

    function endPopupDrag() {
      if (popupEl) {
        popupEl.style.transition = '';
      }
      isDragging = false;
      popupEl = null;
    }

    // Mouse events
    handle.addEventListener('mousedown', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      startPopupDrag(mouseEvent.clientX, mouseEvent.clientY, mouseEvent.target as HTMLElement);
      mouseEvent.preventDefault();
    });

    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (isDragging) {
        e.preventDefault();
        movePopupDrag(e.clientX, e.clientY);
      }
    });
    document.addEventListener('mouseup', endPopupDrag);

    // Touch events - MELHORADOS PARA MOVIMENTO LIVRE
    handle.addEventListener('touchstart', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      startPopupDrag(touch.clientX, touch.clientY, touchEvent.target as HTMLElement);
      // Prevenir comportamento padrão para permitir drag livre
      if (isDragging) {
        e.preventDefault();
      }
    }, { passive: false });

    // Listener global para touchmove com flag de dragging
    const handleTouchMove = (e: TouchEvent) => {
      if (!isDragging) return;
      e.preventDefault(); // Previne scroll durante drag
      const touch = e.touches[0];
      movePopupDrag(touch.clientX, touch.clientY);
    };

    document.addEventListener('touchmove', handleTouchMove, { passive: false });
    document.addEventListener('touchend', endPopupDrag);
    document.addEventListener('touchcancel', endPopupDrag);
  });

  // Click no popup traz para frente
