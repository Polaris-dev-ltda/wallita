---
import Layout from '../layouts/Layout.astro';
import Taskbar from '../components/Taskbar.astro';
import DesktopIcon from '../components/DesktopIcon.astro';
import Window from '../components/Window.astro';

// Ícones SVG detalhados estilo Windows 95/98
const icons = {
  trash: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Base da lixeira -->
    <rect x="10" y="14" width="28" height="30" fill="#4a8c0a"/>
    <rect x="10" y="14" width="28" height="30" fill="#6bb90e"/>
    <rect x="12" y="16" width="24" height="26" fill="#4a8c0a"/>
    <!-- Borda 3D -->
    <rect x="10" y="14" width="2" height="30" fill="#8ed922"/>
    <rect x="10" y="14" width="28" height="2" fill="#8ed922"/>
    <rect x="36" y="14" width="2" height="30" fill="#2d5a06"/>
    <rect x="10" y="42" width="28" height="2" fill="#2d5a06"/>
    <!-- Tampa -->
    <rect x="8" y="10" width="32" height="6" fill="#0066cc"/>
    <rect x="8" y="10" width="32" height="2" fill="#3399ff"/>
    <rect x="8" y="10" width="2" height="6" fill="#3399ff"/>
    <rect x="38" y="10" width="2" height="6" fill="#004499"/>
    <!-- Alça -->
    <rect x="18" y="4" width="12" height="8" fill="#ffcc00"/>
    <rect x="18" y="4" width="12" height="2" fill="#ffee66"/>
    <rect x="20" y="6" width="8" height="4" fill="#0d0d0d"/>
    <!-- Linhas da lixeira - coloridas -->
    <rect x="16" y="20" width="3" height="18" fill="#ff6600"/>
    <rect x="23" y="20" width="3" height="18" fill="#cc0000"/>
    <rect x="30" y="20" width="3" height="18" fill="#ff6600"/>
  </svg>`,
  calendar: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Corpo do calendário -->
    <rect x="4" y="10" width="40" height="34" fill="#f0f0f0"/>
    <rect x="4" y="10" width="2" height="34" fill="#fff"/>
    <rect x="4" y="10" width="40" height="2" fill="#fff"/>
    <rect x="42" y="10" width="2" height="34" fill="#999"/>
    <rect x="4" y="42" width="40" height="2" fill="#999"/>
    <!-- Barra vermelha do topo -->
    <rect x="4" y="10" width="40" height="10" fill="#cc0000"/>
    <rect x="4" y="10" width="40" height="2" fill="#ff3333"/>
    <rect x="4" y="18" width="40" height="2" fill="#990000"/>
    <!-- Argolas douradas -->
    <rect x="12" y="4" width="4" height="12" fill="#ffcc00"/>
    <rect x="12" y="4" width="4" height="2" fill="#ffee66"/>
    <rect x="32" y="4" width="4" height="12" fill="#ffcc00"/>
    <rect x="32" y="4" width="4" height="2" fill="#ffee66"/>
    <!-- Grid de dias colorido -->
    <rect x="8" y="24" width="6" height="6" fill="#0066cc"/>
    <rect x="16" y="24" width="6" height="6" fill="#6bb90e"/>
    <rect x="24" y="24" width="6" height="6" fill="#ff6600"/>
    <rect x="32" y="24" width="6" height="6" fill="#0066cc"/>
    <rect x="8" y="32" width="6" height="6" fill="#6bb90e"/>
    <rect x="16" y="32" width="6" height="6" fill="#ff0000"/>
    <rect x="24" y="32" width="6" height="6" fill="#ffcc00"/>
    <rect x="32" y="32" width="6" height="6" fill="#6bb90e"/>
  </svg>`,
  folder: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Aba da pasta -->
    <rect x="4" y="8" width="18" height="6" fill="#ffcc00"/>
    <rect x="4" y="8" width="18" height="2" fill="#ffee66"/>
    <polygon points="22,8 26,14 22,14" fill="#ff9900"/>
    <!-- Corpo da pasta -->
    <rect x="4" y="14" width="40" height="30" fill="#ffcc00"/>
    <rect x="4" y="14" width="2" height="30" fill="#ffee66"/>
    <rect x="4" y="14" width="40" height="2" fill="#ffee66"/>
    <rect x="42" y="14" width="2" height="30" fill="#cc9900"/>
    <rect x="4" y="42" width="40" height="2" fill="#cc9900"/>
    <!-- Detalhe interno -->
    <rect x="8" y="20" width="32" height="18" fill="#ff9900" fill-opacity="0.3"/>
    <!-- Linhas de papel dentro -->
    <rect x="12" y="24" width="20" height="2" fill="#0066cc"/>
    <rect x="12" y="30" width="16" height="2" fill="#cc0000"/>
  </svg>`,
  video: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Corpo da fita/TV -->
    <rect x="4" y="8" width="40" height="32" fill="#333"/>
    <rect x="4" y="8" width="40" height="2" fill="#555"/>
    <rect x="4" y="8" width="2" height="32" fill="#555"/>
    <rect x="42" y="8" width="2" height="32" fill="#111"/>
    <rect x="4" y="38" width="40" height="2" fill="#111"/>
    <!-- Tela -->
    <rect x="8" y="12" width="32" height="24" fill="#0d0d0d"/>
    <rect x="10" y="14" width="28" height="20" fill="#0066cc"/>
    <!-- Botão play vermelho -->
    <polygon points="18,18 18,30 30,24" fill="#cc0000"/>
    <polygon points="20,20 20,28 27,24" fill="#ff3333"/>
    <!-- Detalhes coloridos -->
    <rect x="8" y="12" width="32" height="2" fill="#ffcc00"/>
    <circle cx="38" cy="36" r="2" fill="#ff0000"/>
    <circle cx="33" cy="36" r="2" fill="#6bb90e"/>
    <circle cx="28" cy="36" r="2" fill="#0066cc"/>
  </svg>`,
  audio: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- CD/Disco colorido -->
    <circle cx="20" cy="24" r="18" fill="#1a1a1a"/>
    <circle cx="20" cy="24" r="16" fill="#cc0000"/>
    <circle cx="20" cy="24" r="14" fill="#ff6600"/>
    <circle cx="20" cy="24" r="10" fill="#ffcc00"/>
    <circle cx="20" cy="24" r="4" fill="#1a1a1a"/>
    <circle cx="20" cy="24" r="2" fill="#fff"/>
    <!-- Reflexo -->
    <ellipse cx="14" cy="18" rx="4" ry="2" fill="#fff" fill-opacity="0.5"/>
    <!-- Ondas de som coloridas -->
    <rect x="36" y="12" width="3" height="24" fill="#0066cc"/>
    <rect x="36" y="10" width="3" height="2" fill="#3399ff"/>
    <rect x="40" y="16" width="3" height="16" fill="#6bb90e"/>
    <rect x="40" y="14" width="3" height="2" fill="#8ed922"/>
    <rect x="44" y="20" width="2" height="8" fill="#ff00ff"/>
  </svg>`,
  file: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Página principal -->
    <rect x="8" y="4" width="28" height="40" fill="#f0f0f0"/>
    <rect x="8" y="4" width="2" height="40" fill="#fff"/>
    <rect x="8" y="4" width="28" height="2" fill="#fff"/>
    <rect x="34" y="4" width="2" height="40" fill="#ccc"/>
    <rect x="8" y="42" width="28" height="2" fill="#ccc"/>
    <!-- Dobra do canto -->
    <polygon points="28,4 36,4 36,12 28,12" fill="#ddd"/>
    <polygon points="28,4 36,12 28,12" fill="#bbb"/>
    <rect x="28" y="4" width="8" height="2" fill="#fff"/>
    <!-- Linhas de texto verdes -->
    <rect x="12" y="18" width="20" height="2" fill="#6bb90e"/>
    <rect x="12" y="24" width="18" height="2" fill="#6bb90e"/>
    <rect x="12" y="30" width="22" height="2" fill="#6bb90e"/>
    <rect x="12" y="36" width="14" height="2" fill="#6bb90e"/>
    <!-- Detalhe -->
    <rect x="12" y="8" width="12" height="4" fill="#4a8c0a"/>
  </svg>`,
  warning: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Triângulo externo -->
    <polygon points="24,2 46,42 2,42" fill="#ffcc00"/>
    <polygon points="24,6 42,40 6,40" fill="#ffee00"/>
    <!-- Borda 3D -->
    <polygon points="24,2 24,6 6,40 2,42" fill="#ffff66"/>
    <polygon points="24,2 24,6 42,40 46,42" fill="#cc9900"/>
    <rect x="2" y="40" width="44" height="2" fill="#996600"/>
    <!-- Triângulo interno verde -->
    <polygon points="24,10 38,38 10,38" fill="#6bb90e"/>
    <!-- Exclamação -->
    <rect x="22" y="16" width="4" height="12" fill="#0d0d0d"/>
    <rect x="22" y="18" width="2" height="8" fill="#333"/>
    <rect x="22" y="32" width="4" height="4" fill="#0d0d0d"/>
  </svg>`,
  photo: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Moldura externa colorida -->
    <rect x="2" y="6" width="44" height="36" fill="#0066cc"/>
    <rect x="2" y="6" width="44" height="2" fill="#3399ff"/>
    <rect x="2" y="6" width="2" height="36" fill="#3399ff"/>
    <rect x="44" y="6" width="2" height="36" fill="#004499"/>
    <rect x="2" y="40" width="44" height="2" fill="#004499"/>
    <!-- Área da foto -->
    <rect x="6" y="10" width="36" height="28" fill="#1a1a1a"/>
    <rect x="8" y="12" width="32" height="24" fill="#87ceeb"/>
    <!-- Sol -->
    <circle cx="34" cy="18" r="4" fill="#ffcc00"/>
    <circle cx="34" cy="18" r="3" fill="#ffee66"/>
    <!-- Montanhas coloridas -->
    <polygon points="8,36 20,20 32,36" fill="#6bb90e"/>
    <polygon points="10,36 20,22 30,36" fill="#8ed922"/>
    <polygon points="22,36 32,24 40,36" fill="#ff6600"/>
    <polygon points="24,36 32,26 38,36" fill="#ffcc00"/>
  </svg>`
};

// Fotos da galeria
const photos = [
  '/images/foto1.jpeg',
  '/images/foto2.jpeg',
  '/images/foto3.jpeg',
  '/images/foto4.jpeg',
  '/images/foto5.jpeg',
  '/images/foto6.jpeg'
];
---

<Layout title="Wallita">
  <div class="desktop" id="desktop">
    <!-- Background com capa e logo -->
    <div class="desktop-bg">
      <img src="/images/capaalbum.jpeg" alt="Capa do álbum" class="bg-album" />
      <img src="/images/Wallita.png" alt="Wallita Logo" class="bg-logo" />
    </div>

    <!-- Ícones do Desktop - espalhados por TODA a tela em cantos EXTREMOS -->
    <DesktopIcon id="win-trash" label="Lixeira" icon={icons.trash} x={15} y={10} />
    <DesktopIcon id="win-folder1" label="Fotos" icon={icons.photo} x={15} y={520} />
    <DesktopIcon id="win-videos" label="Videos" icon={icons.video} x={1280} y={15} />
    <DesktopIcon id="win-audio" label="Audio" icon={icons.audio} x={1280} y={480} />
    <DesktopIcon id="win-calendar" label="Agenda" icon={icons.calendar} x={1150} y={260} />
    <DesktopIcon id="win-folder2" label="Downloads" icon={icons.folder} x={620} y={10} />
    <DesktopIcon id="win-readme" label="Leia-me.txt" icon={icons.file} x={280} y={520} />
    <DesktopIcon id="win-folder3" label="Secreto" icon={icons.folder} x={900} y={500} />
    <DesktopIcon id="win-folder4" label="Stuff" icon={icons.folder} x={480} y={280} />

    <!-- Janela: Lixeira (Spotify) -->
    <Window id="win-trash" title="Lixeira - Spotify" width={450} height={350} x={150} y={80}>
      <div class="content-center">
        <p style="margin-bottom: 16px; text-align: center;">
          A gente joga fora o que nao presta...<br>
          mas as vezes a gente RECICLA.
        </p>
        <a href="https://open.spotify.com/intl-pt/artist/2KPeAwg1B1P3WROMy9JdQk" target="_blank" class="big-link">
          OUVIR NO SPOTIFY
        </a>
        <iframe
          style="border-radius:12px; margin-top: 16px;"
          src="https://open.spotify.com/embed/artist/2KPeAwg1B1P3WROMy9JdQk?utm_source=generator&theme=0"
          width="100%"
          height="152"
          frameBorder="0"
          allowfullscreen=""
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy">
        </iframe>
      </div>
    </Window>

    <!-- Janela: Agenda -->
    <Window id="win-calendar" title="Agenda - Shows" width={400} height={300} x={200} y={100}>
      <div class="content-list">
        <h3 style="margin-bottom: 12px; color: var(--title-bar);">PROXIMOS SHOWS</h3>
        <div class="show-item">
          <span class="show-date">EM BREVE</span>
          <span class="show-info">Fique ligado nas redes!</span>
        </div>
        <p style="margin-top: 16px; font-size: 8px; color: #666;">
          Acompanhe @wallita para novidades
        </p>
      </div>
    </Window>

    <!-- Janela: Vídeos -->
    <Window id="win-videos" title="Videos" width={560} height={400} x={180} y={60}>
      <div class="video-container">
        <iframe
          width="100%"
          height="315"
          src="https://www.youtube.com/embed/OqDDSTlLU7Q"
          title="Wallita"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </Window>

    <!-- Janela: Áudio -->
    <Window id="win-audio" title="Audio Player" width={400} height={250} x={250} y={120}>
      <div class="content-center">
        <p style="margin-bottom: 12px;">Player de Audio</p>
        <div class="audio-visual">
          <div class="bar"></div>
          <div class="bar"></div>
          <div class="bar"></div>
          <div class="bar"></div>
          <div class="bar"></div>
          <div class="bar"></div>
          <div class="bar"></div>
        </div>
        <p style="margin-top: 16px; font-size: 8px;">
          Acesse o Spotify para ouvir!
        </p>
      </div>
    </Window>

    <!-- Janela: Fotos - GALERIA -->
    <Window id="win-folder1" title="Fotos" width={650} height={480} x={120} y={50}>
      <div class="photo-gallery">
        {photos.map((photo, i) => (
          <div class="photo-item">
            <img src={photo} alt={`Foto ${i + 1}`} loading="lazy" />
          </div>
        ))}
      </div>
    </Window>

    <!-- Janela: Downloads -->
    <Window id="win-folder2" title="Downloads" width={350} height={250} x={240} y={110}>
      <div class="content-center">
        <p>Nada para baixar ainda...</p>
        <p style="font-size: 8px; margin-top: 8px; color: #666;">Fique ligado!</p>
      </div>
    </Window>

    <!-- Janela: Readme -->
    <Window id="win-readme" title="Leia-me.txt - Bloco de Notas" width={450} height={340} x={200} y={80}>
      <div class="notepad-content">
        <div class="readme-text">
=======================================
           W A L L I T A
=======================================

Somos a Wallita.

Fazemos som.

Segue a gente:
- Spotify: <a href="https://open.spotify.com/intl-pt/artist/2KPeAwg1B1P3WROMy9JdQk?si=iTGkUKrCRReSXGy8DhOK5A&nd=1&dlsi=0e2e6422f64649b7" target="_blank" class="readme-link">/wallita</a>
- Youtube: <a href="https://www.youtube.com/@WallitaBand" target="_blank" class="readme-link">@WallitaBand</a>
- Instagram: <a href="https://www.instagram.com/wallitaband/" target="_blank" class="readme-link">@wallitaband</a>
- Facebook: <a href="https://www.facebook.com/profile.php?id=61579995254572" target="_blank" class="readme-link">/Wallita</a>
- Wikipédia: <a href="https://pt.wikipedia.org/wiki/Trepanação" target="_blank" class="readme-link">/clica</a>

Valeu!

=======================================
        </div>
      </div>
    </Window>

    <!-- Janela: Secreto - Caveira Dance -->
    <Window id="win-folder3" title="Secreto - ??? " width={400} height={360} x={300} y={100}>
      <div class="video-container secreto-video">
        <video
          src="/videos/caveiradance.mp4"
          autoplay
          loop
          muted
          playsinline
          controls
          style="width: 100%; height: 100%; object-fit: contain; background: #000;">
        </video>
      </div>
    </Window>

    <!-- Janela: Stuff -->
    <Window id="win-folder4" title="Stuff" width={300} height={200} x={350} y={180}>
      <div class="content-center">
        <p>Coisas aleatorias</p>
        <p style="font-size: 8px; margin-top: 8px; color: #666;">Em construcao...</p>
      </div>
    </Window>

    <!-- POPUPS DE VÍRUS - posições espalhadas, arrastáveis -->
    <div class="popup-container" id="popupContainer">
      <!-- Popup 1 - MÃES SOLTEIRAS -->
      <div class="virus-popup solteira-popup" id="popup1" data-popup-draggable style="left: 80px; top: 60px; display: none; width: 340px;">
        <div class="popup-title" data-popup-drag-handle style="background: #ff1493;">
          <span>ENCONTROS NA SUA AREA!</span>
          <button class="popup-close" data-popup-close="popup1">X</button>
        </div>
        <div class="popup-body solteira-body">
          <img src="/images/solteira.jpeg" alt="Solteira" class="solteira-img" />
          <p class="solteira-text">
            MAES SOLTEIRAS BUSCAM HOMENS QUE OUVEM WALLITA
          </p>
          <p class="solteira-subtext">FALE COM UMA AGORA!</p>
          <button class="solteira-btn blink-btn" id="faleComElaBtn">
            FALE COM ELA!!
          </button>
        </div>
      </div>

      <!-- Popup 7 - FOGOS DE ARTIFÍCIO -->
      <div class="virus-popup fireworks-popup" id="popup7" data-popup-draggable style="left: 300px; top: 150px; display: none; width: 450px;">
        <div class="popup-title" data-popup-drag-handle style="background: linear-gradient(90deg, #ff0000, #ff7f00, #ffff00, #00ff00, #0000ff, #8b00ff); animation: rainbowBg 1s linear infinite;">
          <span class="rainbow-text">PARABENS!!!</span>
          <button class="popup-close" data-popup-close="popup7">X</button>
        </div>
        <div class="popup-body fireworks-body">
          <div class="fireworks-container" id="fireworksContainer"></div>
          <p class="fireworks-text rainbow-blink">
            ELAS ESTARAO NO NOSSO PROXIMO SHOW!
          </p>
          <p style="font-size: 10px; margin-top: 12px; color: #000;">Fique ligado na agenda!</p>
          <!-- Áudio de fogos -->
          <audio id="fogosAudio" src="/sounds/fogos.mpeg" preload="auto"></audio>
        </div>
      </div>

      <!-- Popup 2 - YouTube - centro direita -->
      <div class="virus-popup" id="popup2" data-popup-draggable style="left: 500px; top: 150px; display: none; width: 400px;">
        <div class="popup-title" data-popup-drag-handle>
          <span>WALLITA - CLIPE OFICIAL</span>
          <button class="popup-close" data-popup-close="popup2">X</button>
        </div>
        <div class="popup-body" style="padding: 0;">
          <iframe
            width="100%"
            height="225"
            src="https://www.youtube.com/embed/OqDDSTlLU7Q?autoplay=1&mute=1"
            title="Wallita"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      </div>

      <!-- Popup 3 - VISITANTE 1.000.000 -->
      <div class="virus-popup" id="popup3" data-popup-draggable style="left: 700px; top: 40px; display: none;">
        <div class="popup-title" data-popup-drag-handle style="background: #ff6600;">
          <span>PARABENS!!!</span>
          <button class="popup-close" data-popup-close="popup3">X</button>
        </div>
        <div class="popup-body">
          <p style="font-size: 24px; margin-bottom: 8px;">🎉</p>
          <p style="font-weight: bold;">VOCE E O VISITANTE 1.000.000!</p>
          <p style="font-size: 8px; margin-top: 4px;">Clique para resgatar seu IPHONE 15!</p>
          <button class="win95-btn popup-btn" data-popup-close="popup3">RESGATAR</button>
        </div>
      </div>

      <!-- Popup 4 - AUMENTE SEU AMIGÃO -->
      <div class="virus-popup" id="popup4" data-popup-draggable style="left: 60px; top: 280px; display: none; width: 320px;">
        <div class="popup-title" data-popup-drag-handle style="background: #9932cc;">
          <span>OFERTA ESPECIAL!!!</span>
          <button class="popup-close" data-popup-close="popup4">X</button>
        </div>
        <div class="popup-body" style="background: linear-gradient(135deg, #4a0080, #800080);">
          <p style="color: #ffff00; font-weight: bold; font-size: 11px; text-shadow: 1px 1px #000;">AUMENTE O TAMANHO DO SEU AMIGAO!</p>
          <div style="display: flex; gap: 8px; justify-content: center; margin: 10px 0;">
            <img src="/images/berinjela1.jpeg" alt="" style="width: 60px; height: 60px; object-fit: cover; border: 2px solid #ffff00;">
            <img src="/images/berinjela2.jpeg" alt="" style="width: 60px; height: 60px; object-fit: cover; border: 2px solid #ffff00;">
          </div>
          <p style="color: #fff; font-size: 7px; margin-bottom: 8px;">Metodo 100% NATURAL e GARANTIDO!</p>
          <a href="https://www.instagram.com/wallitaband/" target="_blank" class="win95-btn popup-btn" style="text-decoration: none; display: inline-block; background: #ffff00; color: #000;">
            VA NO SHOW DA WALLITA!
          </a>
        </div>
      </div>

      <!-- Popup 5 - CONTA DELETADA -->
      <div class="virus-popup" id="popup5" data-popup-draggable style="left: 350px; top: 200px; display: none;">
        <div class="popup-title" data-popup-drag-handle>
          <span>Microsoft Security</span>
          <button class="popup-close" data-popup-close="popup5">X</button>
        </div>
        <div class="popup-body">
          <p style="font-size: 24px; margin-bottom: 8px;">⚠️</p>
          <p>Sua conta sera DELETADA em 24h!</p>
          <p style="font-size: 8px; margin-top: 4px;">Clique para verificar identidade</p>
          <a href="https://open.spotify.com/intl-pt/artist/2KPeAwg1B1P3WROMy9JdQk" target="_blank" class="win95-btn popup-btn" style="text-decoration: none; display: inline-block;">
            VERIFICAR
          </a>
        </div>
      </div>

      <!-- Popup 6 - HOT SINGLES -->
      <div class="virus-popup" id="popup6" data-popup-draggable style="left: 600px; top: 350px; display: none;">
        <div class="popup-title" data-popup-drag-handle style="background: #ff1493;">
          <span>ENCONTROS</span>
          <button class="popup-close" data-popup-close="popup6">X</button>
        </div>
        <div class="popup-body">
