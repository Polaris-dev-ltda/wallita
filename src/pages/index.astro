  // Sistema de fogos de artifício pixelados
  let fireworksRunning = false;

  function startFireworks() {
    const container = document.getElementById('fireworksContainer');
    if (!container || fireworksRunning) return;

    fireworksRunning = true;
    container.innerHTML = ''; // Limpa fogos anteriores

    const colors = ['#ff0000', '#ff7f00', '#ffff00', '#00ff00', '#00ffff', '#0000ff', '#ff00ff', '#ffffff', '#ff1493', '#7fff00'];

    function createFirework() {
      const containerWidth = container.offsetWidth || 400;
      const containerHeight = container.offsetHeight || 200;
      const x = Math.random() * (containerWidth - 50) + 25;
      const y = Math.random() * (containerHeight - 50) + 25;
      const color = colors[Math.floor(Math.random() * colors.length)];

      // Centro do fogo - explosão principal
      const center = document.createElement('div');
      center.style.cssText = `
        position: absolute;
        left: ${x}px;
        top: ${y}px;
        width: 8px;
        height: 8px;
        background: ${color};
        box-shadow: 0 0 15px ${color}, 0 0 30px ${color};
        animation: fireworkPop 0.5s ease-out forwards;
      `;
      container.appendChild(center);

      // Partículas que explodem em todas as direções
      for (let i = 0; i < 12; i++) {
        const spark = document.createElement('div');
        const angle = (i / 12) * Math.PI * 2;
        const distance = 30 + Math.random() * 40;
        const endX = Math.cos(angle) * distance;
        const endY = Math.sin(angle) * distance;

        spark.style.cssText = `
          position: absolute;
          left: ${x}px;
          top: ${y}px;
          width: 6px;
          height: 6px;
          background: ${color};
          box-shadow: 0 0 8px ${color};
          animation: sparkExplode 0.8s ease-out forwards;
          --end-x: ${endX}px;
          --end-y: ${endY}px;
        `;
        container.appendChild(spark);

        // Remove depois da animação
        setTimeout(() => spark.remove(), 800);
      }

      // Remove centro depois da animação
      setTimeout(() => center.remove(), 500);
    }

    // Lançar vários fogos rapidamente
    let count = 0;
    const maxFireworks = 60;

    const fireworkInterval = setInterval(() => {
      createFirework();
      // Às vezes cria 2 de uma vez
      if (Math.random() > 0.5) createFirework();
      count++;

      if (count >= maxFireworks) {
        clearInterval(fireworkInterval);
        // Reinicia depois de uma pausa
        setTimeout(() => {
          const popup7 = document.getElementById('popup7');
          if (popup7 && popup7.style.display !== 'none') {
            fireworksRunning = false;
            startFireworks();
          } else {
            fireworksRunning = false;
          }
        }, 2000);
      }
    }, 100);
  }

