  // ========== SISTEMA DE AGENDA COM GOOGLE SHEETS ==========
  // Endpoint Google Visualization API - suporta CORS nativamente
  const GOOGLE_SHEETS_CSV_URL = 'https://docs.google.com/spreadsheets/d/1lJnLSAmD84LHRwj9aQt0b55iogYz97pFGsz9pd3hgH8/gviz/tq?tqx=out:csv&gid=0';
  const FETCH_TIMEOUT = 5000;

  let isLoadingAgenda = false;

  // Parser flexível - suporta múltiplos formatos da planilha
  function parseShowLineClient(line: string): {date: string, city: string, venue: string} | null {
    const trimmed = line.replace(/^"|"$/g, '').trim();

    // Formato: "DD.MM - LOCAL / CIDADE" ou "DD/MM - LOCAL / CIDADE"
    const dashMatch = trimmed.match(/^["']?(\d{1,2})[.\/](\d{1,2})\s*-\s*(.+)$/);
    if (dashMatch) {
      const date = `${dashMatch[1]}/${dashMatch[2]}`;
      const rest = dashMatch[3].trim();
      const slashIdx = rest.lastIndexOf('/');
      if (slashIdx > 0) {
        const venue = rest.substring(0, slashIdx).trim();
        const city = rest.substring(slashIdx + 1).trim();
        return { date, city: city.toUpperCase(), venue: venue.toUpperCase() };
      }
      return { date, city: rest.toUpperCase(), venue: '' };
    }

    // Formato CSV: "DD/MM,CIDADE,LOCAL"
    if (trimmed.includes(',')) {
      const parts = trimmed.split(',').map((p: string) => p.trim().replace(/^"|"$/g, ''));
      const dateMatch = parts[0].match(/^(\d{1,2})[.\/](\d{1,2})/);
      if (dateMatch && parts.length >= 2) {
        return {
          date: `${dateMatch[1]}/${dateMatch[2]}`,
          city: (parts[1] || '').toUpperCase(),
          venue: (parts[2] || '').toUpperCase()
        };
      }
    }

    return null;
  }

  function parseCSV(csv: string): Array<{date: string, city: string, venue: string}> {
    const lines = csv.split('\n').filter(line => line.trim() !== '');
    const shows: Array<{date: string, city: string, venue: string}> = [];

    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed ||
          trimmed.toLowerCase().includes('data') ||
          trimmed.toLowerCase().includes('agenda') ||
          trimmed.toLowerCase().includes('shows')) {
        continue;
      }
      const show = parseShowLineClient(trimmed);
      if (show) shows.push(show);
    }

    return shows;
  }

  function renderAgenda(shows: Array<{date: string, city: string, venue: string}>) {
    const container = document.getElementById('agendaContent');
    if (!container) return;

    if (shows.length === 0) {
      container.textContent = `=======================================
       PROXIMOS SHOWS
=======================================

   Nenhum show agendado no momento.
   Fique ligado nas redes!

=======================================`;
      return;
    }

    const months = ['JAN', 'FEV', 'MAR', 'ABR', 'MAI', 'JUN', 'JUL', 'AGO', 'SET', 'OUT', 'NOV', 'DEZ'];
    let text = `=======================================
       PROXIMOS SHOWS
=======================================\n\n`;

    for (let i = 0; i < shows.length; i++) {
      const show = shows[i];
      const [day, month] = show.date.split('/');
      const monthName = months[parseInt(month) - 1] || month;
      text += `${day} ${monthName} - ${show.venue ? show.venue : ''}\n`;
      text += `         ${show.city}`;
      if (i < shows.length - 1) {
        text += `\n---------------------------------------\n`;
      }
    }

    text += `\n\n=======================================
Siga @wallitaband no Instagram
para nao perder nenhum show!
=======================================`;

    container.textContent = text;
  }

  // Carregar agenda do Google Sheets (direto, sem proxy CORS)
  async function loadAgenda() {
    if (isLoadingAgenda) return;
    isLoadingAgenda = true;

    const container = document.getElementById('agendaContent');
    if (!container) { isLoadingAgenda = false; return; }

    try {
      const response = await Promise.race([
        fetch(GOOGLE_SHEETS_CSV_URL, { method: 'GET', cache: 'no-store' }),
        new Promise<Response>((_, reject) =>
          setTimeout(() => reject(new Error('Timeout')), FETCH_TIMEOUT)
        )
      ]);

      if (response.ok) {
        const csv = await response.text();
        const shows = parseCSV(csv);
        if (shows.length > 0) {
          console.log('Agenda atualizada:', shows.length, 'shows');
          renderAgenda(shows);
        }
      }
    } catch (error) {
      console.warn('Erro ao atualizar agenda:', error);
      // Mantém o conteúdo pré-renderizado do build
    } finally {
      isLoadingAgenda = false;
    }
  }

  // Observar quando a janela da agenda é aberta
  const calendarWindow = document.getElementById('win-calendar');
  if (calendarWindow) {
    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
          const display = (calendarWindow as HTMLElement).style.display;
          if (display !== 'none' && display !== '') {
            loadAgenda();
          }
        }
      }
    });
    observer.observe(calendarWindow, { attributes: true });
  }

  const calendarIcon = document.querySelector('[data-window-id="win-calendar"]');
  if (calendarIcon) {
    calendarIcon.addEventListener('click', () => setTimeout(loadAgenda, 100));
    calendarIcon.addEventListener('dblclick', () => setTimeout(loadAgenda, 100));
  }

  // ========== SISTEMA DE DESENHO ==========
  const drawBtn = document.getElementById('drawBtn');
  const drawOverlay = document.getElementById('drawOverlay');
  const drawCanvas = document.getElementById('drawCanvas') as HTMLCanvasElement;
  const drawCloseBtn = document.getElementById('drawCloseBtn');
  const colorBtns = document.querySelectorAll('.color-btn');

  let isDrawingMode = false;
  let isDrawing = false;
  let currentColor = '#ff0000';
  let ctx: CanvasRenderingContext2D | null = null;
  let lastX = 0;
  let lastY = 0;

  // Inicializar canvas
  function initCanvas() {
    if (!drawCanvas) return;

    // Ajustar tamanho do canvas para a resolução real
    const rect = drawCanvas.getBoundingClientRect();
    drawCanvas.width = rect.width * window.devicePixelRatio;
    drawCanvas.height = rect.height * window.devicePixelRatio;

    ctx = drawCanvas.getContext('2d');
    if (ctx) {
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.lineWidth = 5;
      ctx.strokeStyle = currentColor;
    }
  }

  // Ativar modo de desenho
  function enableDrawMode() {
    isDrawingMode = true;
    if (drawOverlay) drawOverlay.style.display = 'block';
    if (drawBtn) drawBtn.classList.add('active');
    initCanvas();
  }

  // Desativar modo de desenho
  function disableDrawMode() {
    isDrawingMode = false;
    if (drawOverlay) drawOverlay.style.display = 'none';
    if (drawBtn) drawBtn.classList.remove('active');
    // Limpar canvas
    if (ctx && drawCanvas) {
      ctx.clearRect(0, 0, drawCanvas.width, drawCanvas.height);
    }
  }

  // Toggle do modo de desenho
  drawBtn?.addEventListener('click', () => {
    if (isDrawingMode) {
      disableDrawMode();
    } else {
      enableDrawMode();
    }
  });

  // Fechar com botão X
  drawCloseBtn?.addEventListener('click', () => {
    disableDrawMode();
  });

  // Fechar com ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isDrawingMode) {
      disableDrawMode();
    }
  });

  // Selecionar cor
  colorBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      colorBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentColor = (btn as HTMLElement).dataset.color || '#ff0000';
      if (ctx) ctx.strokeStyle = currentColor;
    });
  });

  // Funções de desenho
  function getDrawPosition(e: MouseEvent | TouchEvent): { x: number; y: number } {
    const rect = drawCanvas.getBoundingClientRect();
    if ('touches' in e) {
      return {
        x: e.touches[0].clientX - rect.left,
        y: e.touches[0].clientY - rect.top
      };
    }
    return {
      x: e.clientX - rect.left,
      y: e.clientY - rect.top
    };
  }

  function startDrawing(e: MouseEvent | TouchEvent) {
    if (!isDrawingMode || !ctx) return;
    isDrawing = true;
    const pos = getDrawPosition(e);
    lastX = pos.x;
    lastY = pos.y;
    // Desenhar um ponto inicial
    ctx.beginPath();
    ctx.arc(lastX, lastY, ctx.lineWidth / 2, 0, Math.PI * 2);
    ctx.fillStyle = currentColor;
    ctx.fill();
  }

  function draw(e: MouseEvent | TouchEvent) {
    if (!isDrawing || !ctx) return;
    e.preventDefault();
    const pos = getDrawPosition(e);
    ctx.beginPath();
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(pos.x, pos.y);
    ctx.stroke();
    lastX = pos.x;
    lastY = pos.y;
  }

  function stopDrawing() {
    isDrawing = false;
  }

  // Event listeners para mouse
  drawCanvas?.addEventListener('mousedown', startDrawing);
  drawCanvas?.addEventListener('mousemove', draw);
  drawCanvas?.addEventListener('mouseup', stopDrawing);
  drawCanvas?.addEventListener('mouseleave', stopDrawing);

  // Event listeners para touch
  drawCanvas?.addEventListener('touchstart', (e) => {
    e.preventDefault();
    startDrawing(e);
  }, { passive: false });

  drawCanvas?.addEventListener('touchmove', (e) => {
    e.preventDefault();
    draw(e);
  }, { passive: false });

  drawCanvas?.addEventListener('touchend', stopDrawing);
  drawCanvas?.addEventListener('touchcancel', stopDrawing);

  // Redimensionar canvas ao mudar tamanho da janela
  window.addEventListener('resize', () => {
    if (isDrawingMode) {
      initCanvas();
    }
  });

  // ========== SISTEMA R.I.P. - PRESS F TO PAY RESPECT ==========
  const ripBtn = document.getElementById('ripBtn');
  const popup5Element = document.getElementById('popup5');
  const cryingContainer = document.getElementById('cryingEmojisContainer');

  const cryingEmojis = ['😭', '😢', '💔', '🥺', '😿', '💧', '🖤', '⚰️'];
  let isPayingRespect = false;

  function payRespect() {
    if (isPayingRespect) return;
    isPayingRespect = true;

    // Limpar container
    if (cryingContainer) {
      cryingContainer.innerHTML = '';
    }

    // Criar muitos emojis
    const emojiCount = 30;
    for (let i = 0; i < emojiCount; i++) {
      setTimeout(() => {
        createCryingEmoji();
      }, i * 80);
    }

    // Reset após animação
    setTimeout(() => {
      isPayingRespect = false;
    }, 3500);
  }

  function createCryingEmoji() {
    if (!cryingContainer) return;

    const emoji = document.createElement('div');
    emoji.className = 'crying-emoji' + (Math.random() > 0.5 ? ' sparkle' : '');
    emoji.textContent = cryingEmojis[Math.floor(Math.random() * cryingEmojis.length)];

    // Posição aleatória
    emoji.style.left = Math.random() * (window.innerWidth - 50) + 'px';
    emoji.style.top = Math.random() * (window.innerHeight * 0.6) + 'px';
    emoji.style.fontSize = (30 + Math.random() * 30) + 'px';
    emoji.style.animationDelay = (Math.random() * 0.3) + 's';
    emoji.style.animationDuration = (2 + Math.random() * 1.5) + 's';

    cryingContainer.appendChild(emoji);

    // Remover depois da animação
    setTimeout(() => {
      emoji.remove();
    }, 4000);
  }

  // Click no botão
  ripBtn?.addEventListener('click', () => {
    payRespect();
  });

  // Tecla F (apenas quando popup5 está visível)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'f' || e.key === 'F') {
      // Verificar se popup5 está visível
      if (popup5Element && popup5Element.style.display !== 'none' && popup5Element.style.display !== '') {
        payRespect();
      }
    }
  });

  // ========== SISTEMA MERCH - BANANA TROLL ==========
  const merchBtn = document.getElementById('merchBtn');
  const merchBody = document.getElementById('merchBody');
  const weunweunSound = document.getElementById('weunweunSound') as HTMLAudioElement;
  let bananaRevealed = false;

  merchBtn?.addEventListener('click', () => {
    if (bananaRevealed) return;
    bananaRevealed = true;

    // Tocar som (apenas uma vez)
    if (weunweunSound) {
      weunweunSound.currentTime = 0;
      weunweunSound.play().catch(() => {
        // Ignora erro se autoplay bloqueado
      });
    }

    // Animação de shake no popup
    const popup3El = document.getElementById('popup3');
    if (popup3El) {
      popup3El.style.animation = 'bananaShake 0.5s ease-in-out';
    }

    // Substituir conteúdo após pequeno delay
    setTimeout(() => {
      if (merchBody) {
        merchBody.classList.add('banana-reveal');
        merchBody.innerHTML = `
          <div class="banana-emoji">🍌</div>
          <p class="banana-text">Infelizmente você rodou na banana! 🍌</p>
          <p class="banana-subtext">Só vendemos em nossos shows.<br>Vá no próximo!</p>
          <a href="https://www.instagram.com/wallitaband/" target="_blank" class="banana-link">
            📅 Ver próximos shows
          </a>
        `;
      }
    }, 300);
  });

  // Reset quando popup3 é fechado (para funcionar novamente)
  const popup3CloseBtn = document.querySelector('[data-popup-close="popup3"]');
  popup3CloseBtn?.addEventListener('click', () => {
    // Reset após fechar
    setTimeout(() => {
      bananaRevealed = false;
      if (merchBody) {
        merchBody.classList.remove('banana-reveal');
        merchBody.innerHTML = `
          <p class="merch-title">COMPRE NOSSO MERCH!!!</p>
          <div class="merch-images">
            <img src="/images/ades.png" alt="Adesivos Wallita" class="merch-img" />
            <img src="/images/camis.png" alt="Camisetas Wallita" class="merch-img" />
          </div>
          <p class="merch-subtitle">Adesivos e Camisetas exclusivas!</p>
          <button class="win95-btn merch-btn" id="merchBtn">
            🛒 ADQUIRA AGORA! 🛒
          </button>
        `;
        // Re-attach event listener ao novo botão
        const newMerchBtn = document.getElementById('merchBtn');
        newMerchBtn?.addEventListener('click', () => {
          if (bananaRevealed) return;
          bananaRevealed = true;
          if (weunweunSound) {
            weunweunSound.currentTime = 0;
            weunweunSound.play().catch(() => {});
          }
          const popup3El = document.getElementById('popup3');
          if (popup3El) {
            popup3El.style.animation = 'bananaShake 0.5s ease-in-out';
          }
          setTimeout(() => {
            if (merchBody) {
              merchBody.classList.add('banana-reveal');
              merchBody.innerHTML = `
                <div class="banana-emoji">🍌</div>
                <p class="banana-text">Infelizmente você rodou na banana! 🍌</p>
                <p class="banana-subtext">Só vendemos em nossos shows.<br>Vá no próximo!</p>
                <a href="https://www.instagram.com/wallitaband/" target="_blank" class="banana-link">
                  📅 Ver próximos shows
                </a>
              `;
            }
          }, 300);
        });
      }
    }, 500);
  });

// ========== SISTEMA DE VÍDEOS ==========
document.querySelectorAll('.video-item').forEach(item => {
  item.addEventListener('click', () => {
    const src = (item as HTMLElement).dataset.src;
    const player = document.getElementById('videoPlayer');
    const iframe = document.getElementById('videoIframe') as HTMLIFrameElement;
    const list = document.querySelector('.video-list') as HTMLElement;
    const backBtn = document.getElementById('videoBackBtn') as HTMLElement;

    if (src && player && iframe && list && backBtn) {
      iframe.src = src + '?autoplay=1';
      player.style.display = 'block';
      list.style.display = 'none';
      backBtn.style.display = 'inline-block';
    }
  });
});

const videoBackBtn = document.getElementById('videoBackBtn');
videoBackBtn?.addEventListener('click', () => {
  const player = document.getElementById('videoPlayer');
  const iframe = document.getElementById('videoIframe') as HTMLIFrameElement;
  const list = document.querySelector('.video-list') as HTMLElement;
  const backBtn = document.getElementById('videoBackBtn') as HTMLElement;

  if (player && iframe && list && backBtn) {
    iframe.src = '';
    player.style.display = 'none';
    list.style.display = 'flex';
    backBtn.style.display = 'none';
  }
});
</script>