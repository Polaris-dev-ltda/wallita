<script>
  // Sistema de janelas
  let zIndex = 100;
  let popupZIndex = 5000;
  const minimizedWindows: Map<string, { title: string }> = new Map();

  function bringToFront(windowEl: HTMLElement) {
    zIndex++;
    windowEl.style.zIndex = String(zIndex);
    document.querySelectorAll('[data-window]').forEach(w => w.classList.add('inactive'));
    windowEl.classList.remove('inactive');
  }

  function bringPopupToFront(popupEl: HTMLElement) {
    popupZIndex++;
    popupEl.style.zIndex = String(popupZIndex);
  }

  function openWindow(id: string) {
    const win = document.getElementById(id);
    if (win) {
      win.style.display = 'flex';

      // No mobile, centralizar janela na área visível
      const isMobileNow = window.innerWidth <= 768;
      if (isMobileNow) {
        const winWidth = Math.min(win.offsetWidth, window.innerWidth * 0.95);
        const winHeight = Math.min(win.offsetHeight, window.innerHeight * 0.7);
        const x = Math.max(5, (window.innerWidth - winWidth) / 2);
        const y = Math.max(5, 20); // Sempre no topo
        win.style.left = x + 'px';
        win.style.top = y + 'px';
        win.style.width = winWidth + 'px';
        win.style.maxHeight = (window.innerHeight - 60) + 'px';
      }

      bringToFront(win);
      // Remove da taskbar se estava minimizado
      removeFromTaskbar(id);
    }
  }

  function closeWindow(id: string) {
    const win = document.getElementById(id);
    if (win) {
      win.style.display = 'none';
      // Remove da taskbar ao fechar (não minimizar)
      removeFromTaskbar(id);
    }
  }

  function minimizeWindow(id: string) {
    const win = document.getElementById(id);
    if (win) {
      const titleEl = win.querySelector('.title-text');
      const title = titleEl ? titleEl.textContent || id : id;
      win.style.display = 'none';
      addToTaskbar(id, title);
    }
  }

  function addToTaskbar(id: string, title: string) {
    const taskbarWindows = document.getElementById('taskbarWindows');
    if (!taskbarWindows) return;

    // Não adiciona se já existe
    if (document.getElementById('taskbar-' + id)) return;

    const btn = document.createElement('button');
    btn.className = 'taskbar-item';
    btn.id = 'taskbar-' + id;
    btn.innerHTML = `<span class="taskbar-item-icon">
      <svg viewBox="0 0 16 16" fill="#6bb90e">
        <rect x="1" y="3" width="14" height="10" fill="#6bb90e"/>
        <rect x="1" y="3" width="14" height="3" fill="#000080"/>
      </svg>
    </span><span>${title.substring(0, 15)}</span>`;

    btn.addEventListener('click', () => {
      openWindow(id);
    });

    taskbarWindows.appendChild(btn);
    minimizedWindows.set(id, { title });
  }

  function removeFromTaskbar(id: string) {
    const btn = document.getElementById('taskbar-' + id);
    if (btn) {
      btn.remove();
      minimizedWindows.delete(id);
    }
  }

  // Click nos ícones do desktop
  document.querySelectorAll('.desktop-icon').forEach(icon => {
    icon.addEventListener('dblclick', () => {
      const windowId = (icon as HTMLElement).dataset.windowId;
      if (windowId) openWindow(windowId);
    });

    icon.addEventListener('click', (e) => {
      const windowId = (icon as HTMLElement).dataset.windowId;
      if (windowId) openWindow(windowId);
    });
  });

  // Drag dos ícones do desktop (mouse + touch)
  document.querySelectorAll('.desktop-icon').forEach(iconEl => {
    let isDragging = false;
    let hasMoved = false;
    let startX = 0, startY = 0;
    let iconStartX = 0, iconStartY = 0;

    function startIconDrag(clientX: number, clientY: number) {
      isDragging = true;
      hasMoved = false;
      const icon = iconEl as HTMLElement;
      startX = clientX;
      startY = clientY;
      iconStartX = icon.offsetLeft;
      iconStartY = icon.offsetTop;
    }

    function moveIconDrag(clientX: number, clientY: number) {
      if (!isDragging) return;
      const deltaX = clientX - startX;
      const deltaY = clientY - startY;

      // Só considera drag se moveu mais de 10px
      if (Math.abs(deltaX) > 10 || Math.abs(deltaY) > 10) {
        hasMoved = true;
        const icon = iconEl as HTMLElement;
        const x = Math.max(0, Math.min(iconStartX + deltaX, window.innerWidth - 60));
        const y = Math.max(0, Math.min(iconStartY + deltaY, window.innerHeight - 100));
        icon.style.left = x + 'px';
        icon.style.top = y + 'px';
      }
    }

    function endIconDrag() {
      isDragging = false;
    }

    // Mouse events
    iconEl.addEventListener('mousedown', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      startIconDrag(mouseEvent.clientX, mouseEvent.clientY);
    });

    document.addEventListener('mousemove', (e: MouseEvent) => moveIconDrag(e.clientX, e.clientY));
    document.addEventListener('mouseup', endIconDrag);

    // Touch events
    iconEl.addEventListener('touchstart', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      startIconDrag(touch.clientX, touch.clientY);
    }, { passive: true });

    iconEl.addEventListener('touchmove', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      moveIconDrag(touch.clientX, touch.clientY);
      if (hasMoved) {
        e.preventDefault(); // Previne scroll durante drag
      }
    }, { passive: false });

    iconEl.addEventListener('touchend', endIconDrag);
  });

  // Botões de fechar janela (X) - FECHA completamente
  document.querySelectorAll('[data-close]').forEach(btn => {
    btn.addEventListener('click', () => {
      const win = (btn as HTMLElement).closest('[data-window]') as HTMLElement;
      if (win) {
        win.style.display = 'none';
        removeFromTaskbar(win.id);
      }
    });
  });

  // Botões de minimizar janela (_) - vai para taskbar
  document.querySelectorAll('[data-minimize]').forEach(btn => {
    btn.addEventListener('click', () => {
      const win = (btn as HTMLElement).closest('[data-window]') as HTMLElement;
      if (win) {
        minimizeWindow(win.id);
      }
    });
  });

  // Click na janela traz para frente
  document.querySelectorAll('[data-window]').forEach(win => {
    win.addEventListener('mousedown', () => bringToFront(win as HTMLElement));
  });

  // Drag das janelas normais (mouse + touch)
  document.querySelectorAll('[data-draggable]').forEach(titleBar => {
    let isDragging = false;
    let startX = 0, startY = 0;
    let windowEl: HTMLElement | null = null;

    function startDrag(clientX: number, clientY: number, target: HTMLElement) {
      if (target.closest('.title-btn')) return;
      isDragging = true;
      windowEl = (titleBar as HTMLElement).closest('[data-window]') as HTMLElement;
      if (windowEl) {
        startX = clientX - windowEl.offsetLeft;
        startY = clientY - windowEl.offsetTop;
        bringToFront(windowEl);
      }
    }

    function moveDrag(clientX: number, clientY: number) {
      if (!isDragging || !windowEl) return;
      const x = Math.max(0, Math.min(clientX - startX, window.innerWidth - 100));
      const y = Math.max(0, Math.min(clientY - startY, window.innerHeight - 100));
      windowEl.style.left = x + 'px';
      windowEl.style.top = y + 'px';
    }

    function endDrag() {
      isDragging = false;
      windowEl = null;
    }

    // Mouse events
    titleBar.addEventListener('mousedown', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      startDrag(mouseEvent.clientX, mouseEvent.clientY, mouseEvent.target as HTMLElement);
    });

    document.addEventListener('mousemove', (e: MouseEvent) => moveDrag(e.clientX, e.clientY));
    document.addEventListener('mouseup', endDrag);

    // Touch events
    titleBar.addEventListener('touchstart', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      startDrag(touch.clientX, touch.clientY, touchEvent.target as HTMLElement);
    }, { passive: true });

    document.addEventListener('touchmove', (e: TouchEvent) => {
      const touch = e.touches[0];
      moveDrag(touch.clientX, touch.clientY);
    }, { passive: true });

    document.addEventListener('touchend', endDrag);
  });

  // Drag dos popups de vírus (mouse + touch)
  document.querySelectorAll('[data-popup-drag-handle]').forEach(handle => {
    let isDragging = false;
    let startX = 0, startY = 0;
    let popupEl: HTMLElement | null = null;

    function startPopupDrag(clientX: number, clientY: number, target: HTMLElement) {
      if (target.closest('.popup-close')) return;
      isDragging = true;
      popupEl = (handle as HTMLElement).closest('.virus-popup') as HTMLElement;
      if (popupEl) {
        startX = clientX - popupEl.offsetLeft;
        startY = clientY - popupEl.offsetTop;
        bringPopupToFront(popupEl);
      }
    }

    function movePopupDrag(clientX: number, clientY: number) {
      if (!isDragging || !popupEl) return;
      const x = Math.max(0, Math.min(clientX - startX, window.innerWidth - 100));
      const y = Math.max(0, Math.min(clientY - startY, window.innerHeight - 80));
      popupEl.style.left = x + 'px';
      popupEl.style.top = y + 'px';
    }

    function endPopupDrag() {
      isDragging = false;
      popupEl = null;
    }

    // Mouse events
    handle.addEventListener('mousedown', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      startPopupDrag(mouseEvent.clientX, mouseEvent.clientY, mouseEvent.target as HTMLElement);
      mouseEvent.preventDefault();
    });

    document.addEventListener('mousemove', (e: MouseEvent) => movePopupDrag(e.clientX, e.clientY));
    document.addEventListener('mouseup', endPopupDrag);

    // Touch events
    handle.addEventListener('touchstart', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      startPopupDrag(touch.clientX, touch.clientY, touchEvent.target as HTMLElement);
    }, { passive: true });

    document.addEventListener('touchmove', (e: TouchEvent) => {
      const touch = e.touches[0];
      movePopupDrag(touch.clientX, touch.clientY);
    }, { passive: true });

    document.addEventListener('touchend', endPopupDrag);
  });

  // Click no popup traz para frente
  document.querySelectorAll('.virus-popup').forEach(popup => {
    popup.addEventListener('mousedown', () => bringPopupToFront(popup as HTMLElement));
  });

  // Fechar popups de vírus
  document.querySelectorAll('[data-popup-close]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const popupId = (btn as HTMLElement).dataset.popupClose;
      if (popupId) {
        const popup = document.getElementById(popupId);
        if (popup) popup.style.display = 'none';
      }
    });
  });

  // Detectar se é mobile
  const isMobile = window.innerWidth <= 768;

  // Reposicionar ícones do desktop para mobile - ESPALHADOS pela tela toda
  function repositionIconsForMobile() {
    if (!isMobile) return;

    const screenW = window.innerWidth;
    const screenH = window.innerHeight - 40; // menos taskbar

    const icons = document.querySelectorAll('.desktop-icon');
    // Distribuir em 3 colunas pela tela toda
    const positions = [
      { x: 10, y: 10 },                          // Lixeira - topo esquerdo
      { x: screenW - 70, y: 10 },                // Fotos - topo direito
      { x: Math.floor(screenW / 2) - 30, y: 10 }, // Videos - topo centro
      { x: 10, y: Math.floor(screenH / 2) - 40 }, // Audio - meio esquerdo
      { x: screenW - 70, y: Math.floor(screenH / 2) - 40 }, // Agenda - meio direito
      { x: Math.floor(screenW / 2) - 30, y: Math.floor(screenH / 2) - 40 }, // Downloads - centro
      { x: 10, y: screenH - 120 },               // Leia-me - baixo esquerdo
      { x: screenW - 70, y: screenH - 120 },     // Secreto - baixo direito
      { x: Math.floor(screenW / 2) - 30, y: screenH - 120 }, // Stuff - baixo centro
    ];

    icons.forEach((icon, i) => {
      if (positions[i]) {
        (icon as HTMLElement).style.left = Math.max(5, positions[i].x) + 'px';
        (icon as HTMLElement).style.top = Math.max(5, positions[i].y) + 'px';
      }
    });
  }

  // Animação de vírus na abertura - posições fixas espalhadas
  function startVirusAnimation() {
    const isMobileNow = window.innerWidth <= 768;

    // Posições diferentes para mobile
    const popups = isMobileNow ? [
      { id: 'popup1', x: 10, y: 30 },
      { id: 'popup3', x: 10, y: 120 },
      { id: 'popup4', x: 10, y: 210 },
      { id: 'popup5', x: 10, y: 300 },
      { id: 'popup6', x: 10, y: 390 },
      { id: 'popup2', x: 10, y: 80 }
    ] : [
      { id: 'popup1', x: 80, y: 60 },
      { id: 'popup3', x: 650, y: 40 },
      { id: 'popup4', x: 60, y: 280 },
      { id: 'popup5', x: 350, y: 200 },
      { id: 'popup6', x: 550, y: 380 },
      { id: 'popup2', x: 450, y: 120 }
    ];

    let delay = 0;
    popups.forEach((popupData) => {
      setTimeout(() => {
        const popup = document.getElementById(popupData.id);
        if (popup) {
          const maxX = Math.max(10, window.innerWidth - (isMobileNow ? 100 : 350));
          const maxY = Math.max(10, window.innerHeight - (isMobileNow ? 150 : 300));
          popup.style.left = Math.min(popupData.x, maxX) + 'px';
          popup.style.top = Math.min(popupData.y, maxY) + 'px';
          popup.style.display = 'block';
          bringPopupToFront(popup);
        }
      }, delay);
      delay += 250;
    });
  }

  // Iniciar vírus e reposicionar ícones
  window.addEventListener('load', () => {
    repositionIconsForMobile();
    setTimeout(startVirusAnimation, 100);
  });

  // Botão "Fale com ela" - abre popup de fogos
  const faleComElaBtn = document.getElementById('faleComElaBtn');
  const fogosAudio = document.getElementById('fogosAudio') as HTMLAudioElement;

  if (faleComElaBtn) {
    faleComElaBtn.addEventListener('click', () => {
      const popup7 = document.getElementById('popup7');
      if (popup7) {
        popup7.style.display = 'block';
        bringPopupToFront(popup7);
        startFireworks();
        // Tocar áudio de fogos
        if (fogosAudio) {
          fogosAudio.currentTime = 0;
          fogosAudio.loop = true;
          fogosAudio.play().catch(() => {
            // Ignora erro se autoplay bloqueado
          });
        }
      }
    });
  }

  // Parar áudio quando fechar popup7
  const popup7CloseBtn = document.querySelector('[data-popup-close="popup7"]');
  if (popup7CloseBtn) {
    popup7CloseBtn.addEventListener('click', () => {
      if (fogosAudio) {
        fogosAudio.pause();
        fogosAudio.currentTime = 0;
      }
    });
  }

  // Sistema de fogos de artifício pixelados
  let fireworksRunning = false;

  function startFireworks() {
    const container = document.getElementById('fireworksContainer');
    if (!container || fireworksRunning) return;

    fireworksRunning = true;
    container.innerHTML = ''; // Limpa fogos anteriores

    const colors = ['#ff0000', '#ff7f00', '#ffff00', '#00ff00', '#00ffff', '#0000ff', '#ff00ff', '#ffffff', '#ff1493', '#7fff00'];

    function createFirework() {
      const containerWidth = container.offsetWidth || 400;
      const containerHeight = container.offsetHeight || 200;
      const x = Math.random() * (containerWidth - 50) + 25;
      const y = Math.random() * (containerHeight - 50) + 25;
      const color = colors[Math.floor(Math.random() * colors.length)];

      // Centro do fogo - explosão principal
      const center = document.createElement('div');
      center.style.cssText = `
        position: absolute;
        left: ${x}px;
        top: ${y}px;
        width: 8px;
        height: 8px;
        background: ${color};
        box-shadow: 0 0 15px ${color}, 0 0 30px ${color};
        animation: fireworkPop 0.5s ease-out forwards;
      `;
      container.appendChild(center);

      // Partículas que explodem em todas as direções
      for (let i = 0; i < 12; i++) {
        const spark = document.createElement('div');
        const angle = (i / 12) * Math.PI * 2;
        const distance = 30 + Math.random() * 40;
        const endX = Math.cos(angle) * distance;
        const endY = Math.sin(angle) * distance;

        spark.style.cssText = `
          position: absolute;
          left: ${x}px;
          top: ${y}px;
          width: 6px;
          height: 6px;
          background: ${color};
          box-shadow: 0 0 8px ${color};
          animation: sparkExplode 0.8s ease-out forwards;
          --end-x: ${endX}px;
          --end-y: ${endY}px;
        `;
        container.appendChild(spark);

        // Remove depois da animação
        setTimeout(() => spark.remove(), 800);
      }

      // Remove centro depois da animação
      setTimeout(() => center.remove(), 500);
    }

    // Lançar vários fogos rapidamente
    let count = 0;
    const maxFireworks = 60;

    const fireworkInterval = setInterval(() => {
      createFirework();
      // Às vezes cria 2 de uma vez
      if (Math.random() > 0.5) createFirework();
      count++;

      if (count >= maxFireworks) {
        clearInterval(fireworkInterval);
        // Reinicia depois de uma pausa
        setTimeout(() => {
          const popup7 = document.getElementById('popup7');
          if (popup7 && popup7.style.display !== 'none') {
            fireworksRunning = false;
            startFireworks();
          } else {
            fireworksRunning = false;
          }
        }, 2000);
      }
    }, 100);
  }

  // Adiciona estilos de animação dinamicamente
  const fireworkStyles = document.createElement('style');
  fireworkStyles.textContent = `
    @keyframes fireworkPop {
      0% { transform: scale(0); opacity: 1; }
      50% { transform: scale(3); opacity: 1; }
      100% { transform: scale(0); opacity: 0; }
    }
    @keyframes sparkExplode {
      0% { transform: translate(0, 0) scale(1); opacity: 1; }
      100% { transform: translate(var(--end-x), var(--end-y)) scale(0); opacity: 0; }
    }
  `;
  document.head.appendChild(fireworkStyles);
</script>
