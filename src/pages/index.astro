// ========== BUSCA AGENDA DO GOOGLE SHEETS (BUILD TIME) ==========
const SHEETS_URL = 'https://docs.google.com/spreadsheets/d/1lJnLSAmD84LHRwj9aQt0b55iogYz97pFGsz9pd3hgH8/export?format=csv&gid=0';

// Parser flexível - suporta múltiplos formatos da planilha
function parseShowLine(line: string): {date: string, city: string, venue: string} | null {
  const trimmed = line.replace(/^"|"$/g, '').trim();

  // Formato: "DD.MM  - LOCAL / CIDADE" ou "DD/MM - LOCAL / CIDADE"
  const dashMatch = trimmed.match(/^["']?(\d{1,2})[.\/](\d{1,2})\s*-\s*(.+)$/);
  if (dashMatch) {
    const date = `${dashMatch[1]}/${dashMatch[2]}`;
    const rest = dashMatch[3].trim();
    const slashIdx = rest.lastIndexOf('/');
    if (slashIdx > 0) {
      const venue = rest.substring(0, slashIdx).trim();
      const city = rest.substring(slashIdx + 1).trim();
      return { date, city: city.toUpperCase(), venue: venue.toUpperCase() };
    }
    return { date, city: rest.toUpperCase(), venue: '' };
  }

  // Formato CSV: "DD/MM,CIDADE,LOCAL"
  if (trimmed.includes(',')) {
    const parts = trimmed.split(',').map((p: string) => p.trim().replace(/^"|"$/g, ''));
    const dateMatch = parts[0].match(/^(\d{1,2})[.\/](\d{1,2})/);
    if (dateMatch && parts.length >= 2) {
      return {
        date: `${dateMatch[1]}/${dateMatch[2]}`,
        city: (parts[1] || '').toUpperCase(),
        venue: (parts[2] || '').toUpperCase()
      };
    }
  }

  return null;
}

let buildTimeShows: Array<{date: string, city: string, venue: string}> = [];
try {
  const res = await fetch(SHEETS_URL, { signal: AbortSignal.timeout(10000) });
  if (res.ok) {
    const csv = await res.text();
    const lines = csv.split('\n').filter((l: string) => l.trim() !== '');
    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed ||
          trimmed.toLowerCase().includes('data') ||
          trimmed.toLowerCase().includes('agenda') ||
          trimmed.toLowerCase().includes('shows')) continue;
      const show = parseShowLine(trimmed);
      if (show) buildTimeShows.push(show);
    }
    console.log(`[Build] Agenda: ${buildTimeShows.length} shows carregados da planilha`);
  }
} catch (e) {
  console.warn('Falha ao buscar agenda no build time:', e);
}

