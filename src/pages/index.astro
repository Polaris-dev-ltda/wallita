    function startDrag(clientX: number, clientY: number, target: HTMLElement) {
      if (target.closest('.title-btn')) return;
      isDragging = true;
      windowEl = (titleBar as HTMLElement).closest('[data-window]') as HTMLElement;
      if (windowEl) {
        startX = clientX - windowEl.offsetLeft;
        startY = clientY - windowEl.offsetTop;
        bringToFront(windowEl);
      }
    }

    function moveDrag(clientX: number, clientY: number) {
      if (!isDragging || !windowEl) return;
      const x = Math.max(0, Math.min(clientX - startX, window.innerWidth - 100));
      const y = Math.max(0, Math.min(clientY - startY, window.innerHeight - 100));
      windowEl.style.left = x + 'px';
      windowEl.style.top = y + 'px';
    }

    function endDrag() {
      isDragging = false;
      windowEl = null;
    }

    // Mouse events
    titleBar.addEventListener('mousedown', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      startDrag(mouseEvent.clientX, mouseEvent.clientY, mouseEvent.target as HTMLElement);
