<script>
  // Sistema de janelas
  let zIndex = 100;
  let popupZIndex = 5000;
  const minimizedWindows: Map<string, { title: string }> = new Map();

  function bringToFront(windowEl: HTMLElement) {
  popupZIndex++;
  windowEl.style.zIndex = String(popupZIndex);
  document.querySelectorAll('[data-window]').forEach(w => w.classList.add('inactive'));
  windowEl.classList.remove('inactive');
  }

  function bringPopupToFront(popupEl: HTMLElement) {
    popupZIndex++;
    popupEl.style.zIndex = String(popupZIndex);
  }

  function openWindow(id: string) {
    const win = document.getElementById(id);
    if (win) {
      win.style.display = 'flex';

      // No mobile, centralizar janela na área visível
      const isMobileNow = window.innerWidth <= 768;
      if (isMobileNow) {
        const winWidth = Math.min(win.offsetWidth, window.innerWidth * 0.95);
        const winHeight = Math.min(win.offsetHeight, window.innerHeight * 0.7);
        const x = Math.max(5, (window.innerWidth - winWidth) / 2);
        const y = Math.max(5, 20); // Sempre no topo
        win.style.left = x + 'px';
        win.style.top = y + 'px';
        win.style.width = winWidth + 'px';
        win.style.maxHeight = (window.innerHeight - 60) + 'px';
      }

      bringToFront(win);
      // Remove da taskbar se estava minimizado
      removeFromTaskbar(id);
    }
  }

  function closeWindow(id: string) {
    const win = document.getElementById(id);
    if (win) {
      win.style.display = 'none';
      // Remove da taskbar ao fechar (não minimizar)
      removeFromTaskbar(id);
    }
  }

  function minimizeWindow(id: string) {
    const win = document.getElementById(id);
    if (win) {
      const titleEl = win.querySelector('.title-text');
      const title = titleEl ? titleEl.textContent || id : id;
      win.style.display = 'none';
      addToTaskbar(id, title);
    }
  }

  function addToTaskbar(id: string, title: string) {
    const taskbarWindows = document.getElementById('taskbarWindows');
    if (!taskbarWindows) return;

    // Não adiciona se já existe
    if (document.getElementById('taskbar-' + id)) return;

    const btn = document.createElement('button');
    btn.className = 'taskbar-item';
    btn.id = 'taskbar-' + id;
    btn.innerHTML = `<span class="taskbar-item-icon">
      <svg viewBox="0 0 16 16" fill="#6bb90e">
        <rect x="1" y="3" width="14" height="10" fill="#6bb90e"/>
        <rect x="1" y="3" width="14" height="3" fill="#000080"/>
      </svg>
    </span><span>${title.substring(0, 15)}</span>`;

    btn.addEventListener('click', () => {
      openWindow(id);
    });

    taskbarWindows.appendChild(btn);
    minimizedWindows.set(id, { title });
  }

  function removeFromTaskbar(id: string) {
    const btn = document.getElementById('taskbar-' + id);
    if (btn) {
      btn.remove();
      minimizedWindows.delete(id);
    }
  }

  // Click nos ícones do desktop
  document.querySelectorAll('.desktop-icon').forEach(icon => {
    icon.addEventListener('dblclick', () => {
      const windowId = (icon as HTMLElement).dataset.windowId;
      if (windowId) openWindow(windowId);
    });

    icon.addEventListener('click', (e) => {
      const windowId = (icon as HTMLElement).dataset.windowId;
      if (windowId) openWindow(windowId);
    });
  });

  // Drag dos ícones do desktop (mouse + touch)
  document.querySelectorAll('.desktop-icon').forEach(iconEl => {
    let isDragging = false;
    let hasMoved = false;
    let startX = 0, startY = 0;
    let iconStartX = 0, iconStartY = 0;

    function startIconDrag(clientX: number, clientY: number) {
      isDragging = true;
      hasMoved = false;
      const icon = iconEl as HTMLElement;
      startX = clientX;
      startY = clientY;
      iconStartX = icon.offsetLeft;
      iconStartY = icon.offsetTop;
    }

    function moveIconDrag(clientX: number, clientY: number) {
      if (!isDragging) return;
      const deltaX = clientX - startX;
      const deltaY = clientY - startY;

      // Só considera drag se moveu mais de 10px
      if (Math.abs(deltaX) > 10 || Math.abs(deltaY) > 10) {
        hasMoved = true;
        const icon = iconEl as HTMLElement;
        const x = Math.max(0, Math.min(iconStartX + deltaX, window.innerWidth - 60));
        const y = Math.max(0, Math.min(iconStartY + deltaY, window.innerHeight - 100));
        icon.style.left = x + 'px';
        icon.style.top = y + 'px';
      }
    }

    function endIconDrag() {
      isDragging = false;
    }

    // Mouse events
    iconEl.addEventListener('mousedown', (e: Event) => {
      const mouseEvent = e as MouseEvent;
      startIconDrag(mouseEvent.clientX, mouseEvent.clientY);
    });

    document.addEventListener('mousemove', (e: MouseEvent) => moveIconDrag(e.clientX, e.clientY));
    document.addEventListener('mouseup', endIconDrag);

    // Touch events
    iconEl.addEventListener('touchstart', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      startIconDrag(touch.clientX, touch.clientY);
    }, { passive: true });

    iconEl.addEventListener('touchmove', (e: Event) => {
      const touchEvent = e as TouchEvent;
      const touch = touchEvent.touches[0];
      moveIconDrag(touch.clientX, touch.clientY);
