---
interface Props {
  id: string;
  label: string;
  icon: string;
  x?: number;
  y?: number;
}

const { id, label, icon, x = 20, y = 20 } = Astro.props;
---

<div
  class="desktop-icon"
  data-window-id={id}
  style={`left: ${x}px; top: ${y}px;`}
>
  <div class="icon-image">
    <Fragment set:html={icon} />
  </div>
  <span class="icon-label">{label}</span>
</div>

<style>
  .desktop-icon {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 80px;
    padding: 8px;
    cursor: pointer;
    user-select: none;
  }

  .desktop-icon:hover .icon-label {
    background: var(--neon-green);
    color: var(--bg-dark);
  }

  .desktop-icon:active {
    transform: scale(0.95);
  }

  .icon-image {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
    image-rendering: pixelated;
  }

  .icon-image :global(svg) {
    width: 100%;
    height: 100%;
  }

  .icon-label {
    font-size: 8px;
    text-align: center;
    color: var(--neon-green);
    text-shadow: 1px 1px 0 var(--bg-dark), -1px -1px 0 var(--bg-dark), 1px -1px 0 var(--bg-dark), -1px 1px 0 var(--bg-dark);
    padding: 2px 4px;
    word-break: break-word;
    line-height: 1.4;
  }
</style>
